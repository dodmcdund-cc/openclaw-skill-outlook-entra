# ============================================================
# Outlook Entra — Configuration OAuth 2.0 (device code flow)
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# ── Identifiants de l'app Entra ────────────────────────────
# GUID du tenant Azure AD
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Application (client) ID — trouvé dans Entra App Registrations
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Client secret — généré dans Certificates & secrets
AZURE_CLIENT_SECRET=your_client_secret_here

# ── Endpoints OAuth 2.0 ───────────────────────────────────
OAUTH_DEVICE_CODE_URL=https://login.microsoftonline.com/${AZURE_TENANT_ID}/oauth2/v2.0/devicecode
OAUTH_TOKEN_URL=https://login.microsoftonline.com/${AZURE_TENANT_ID}/oauth2/v2.0/token

# ── Microsoft Graph ────────────────────────────────────────
MS_GRAPH_BASE_URL=https://graph.microsoft.com/v1.0

# ── Scope OAuth 2.0 device code ────────────────────────────
# offline_access requis pour obtenir un refresh_token.
# Les permissions Graph (Mail.Read, Calendars.Read, Contacts.Read)
# sont accordées par le admin consent dans Entra App Registrations.
SCOPES_DEVICE_CODE=user.read openid profile offline_access

# ── Stockage des tokens ────────────────────────────────────
TOKEN_FILE=~/.openclaw/outlook_tokens.json
TOKEN_FILE_KEY=                     # vide = token en clair ; sinon clé Fernet

# ── Timeout ───────────────────────────────────────────────
REQUEST_TIMEOUT=30
